completed = df[df['test preparation course'] == 'completed']
correlation_matrix = np.corrcoef(completed['reading score'], completed['math score'])
correlation_coefficient = correlation_matrix[0, 1]
print(f'The correlation for math and reading scores for test preppers is {correlation_coefficient}')

ax = mp.axes()
m, b = np.polyfit(completed['reading score'],completed['math score'],1)
mp.scatter(completed['reading score'],completed['math score'])
mp.plot(completed['reading score'], m*completed['reading score'] + b, color='steelblue', linestyle='--', linewidth=2, label=f'Line of best fit: y = {m:.2f}x + {b:.2f}')
numpoints = len(completed['reading score'])
ax.set_xlabel('Reading Score')
ax.set_ylabel('Math Score')
ax.set_title(f'Reading and Math Scores for Test Prep Completers n={numpoints}')
